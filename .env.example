# Optional local archive key for encrypted .rexp imports and exports.
RELUTION_REXP_KEY=CHANGE_ME

# Optional read-only Relution API defaults for `pnpm rexp relution ...`.
RELUTION_BASE_URL=https://relution.example.org
RELUTION_ACCESS_TOKEN=CHANGE_ME

# Optional local Docker E2E overrides.
RELUTION_DOCKER_IMAGE=relution/relution:26.1.1
RELUTION_DOCKER_PORT=8080
RELUTION_DOCKER_MEMORY=1536m
RELUTION_DOCKER_PROJECT=relution-policy-workbench-e2e
RELUTION_E2E_BASE_URL=http://127.0.0.1:8080
RELUTION_E2E_USERNAME=admin
RELUTION_E2E_PASSWORD=CHANGE_ME
RELUTION_E2E_SYSTEM_PASSWORD=CHANGE_ME
RELUTION_E2E_REXP_KEY=CHANGE_ME
RELUTION_E2E_ACCESS_TOKEN=CHANGE_ME
RELUTION_E2E_MANAGEMENT_ACCESS_TOKEN=CHANGE_ME
RELUTION_E2E_POSTGRES_IMAGE=postgres:16-alpine
